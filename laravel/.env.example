# ============================================
# Arfan Barbershop API — Environment Variables
# ============================================
# Untuk Render: isi via Dashboard → Environment
# Jangan commit .env asli ke git!
# ============================================

APP_NAME=Arfan Barbershop
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://arfan-barbershop-api.onrender.com

# Database — Neon PostgreSQL
DB_CONNECTION=pgsql
DB_HOST=
DB_PORT=5432
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=
DB_SSLMODE=require
# DB_DSN_OPTIONS — hanya untuk Neon: options=endpoint=<endpoint-id>

# Midtrans
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
MIDTRANS_IS_PRODUCTION=false
MIDTRANS_IS_SANITIZED=true
MIDTRANS_IS_3DS=true

# Defaults
CACHE_STORE=file
SESSION_DRIVER=file
QUEUE_CONNECTION=sync
LOG_CHANNEL=stack
LOG_LEVEL=debug
